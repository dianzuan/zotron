# Zotero binary — WSL path that Linux existsSync() accepts
# and WSL interop runs as a Windows process
ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/mnt/d/Zotero/zotero.exe

# Profile + data dir — Windows-native paths (Windows Zotero.exe reads these verbatim)
# Use these (pointing at user's main Zotero) only when main Zotero is CLOSED,
# otherwise database lock conflicts. Note: requires node_modules patch to skip
# path.resolve() on Windows-style paths (see README).
ZOTERO_PLUGIN_PROFILE_PATH=C:\Users\<YOU>\AppData\Roaming\Zotero\Zotero\Profiles\<hash>.default
ZOTERO_PLUGIN_DATA_DIR=C:\Users\<YOU>\Zotero
