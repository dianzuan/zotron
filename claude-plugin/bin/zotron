#!/usr/bin/env bash
# Zotron CLI — typed RPC client for the Zotron XPI
# Usage: zotron ping | zotron search quick "..." | zotron rpc <method> '<json>'
set -euo pipefail
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-}}"
if [ -z "${PLUGIN_ROOT}" ]; then
  PLUGIN_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
fi
exec uv run --project "${PLUGIN_ROOT}/python" zotron "$@"
