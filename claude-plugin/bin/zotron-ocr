#!/usr/bin/env bash
# Zotero OCR — cloud OCR for Zotero collections
# Usage: zotron-ocr --collection "数字经济" | zotron-ocr --item 12345
set -euo pipefail
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-${CODEX_PLUGIN_ROOT:-}}"
if [ -z "${PLUGIN_ROOT}" ]; then
  PLUGIN_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
fi
exec uv run --project "${PLUGIN_ROOT}/python" zotron-ocr "$@"
