{
  "manifest_version": 2,
  "name": "Zotron",
  "version": "0.1.0",
  "description": "HTTP JSON-RPC API for Zotero - exposes internal API for external tools",
  "homepage_url": "https://github.com/dianzuan/zotron",
  "author": "diamondrill",
  "icons": {
    "48": "content/icons/icon.png",
    "96": "content/icons/icon@96.png"
  },
  "applications": {
    "zotero": {
      "id": "zotron@diamondrill",
      "update_url": "https://raw.githubusercontent.com/dianzuan/zotron/main/update.json",
      "strict_min_version": "6.999",
      "strict_max_version": "9.*"
    }
  }
}
